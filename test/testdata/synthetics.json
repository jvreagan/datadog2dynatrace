{
  "tests": [
    {
      "public_id": "syn-abc-123",
      "name": "Payment API Health Check",
      "type": "api",
      "subtype": "http",
      "config": {
        "request": {
          "method": "GET",
          "url": "https://api.example.com/v1/health",
          "headers": {
            "Accept": "application/json",
            "X-API-Key": "{{PAYMENT_API_KEY}}"
          },
          "timeout": 30
        },
        "assertions": [
          {"type": "statusCode", "operator": "is", "target": 200},
          {"type": "responseTime", "operator": "lessThan", "target": 2000},
          {"type": "body", "operator": "contains", "target": "healthy"}
        ]
      },
      "options": {
        "tick_every": 60,
        "min_failure_duration": 0,
        "min_location_failed": 1,
        "follow_redirects": true,
        "retry": {"count": 2, "interval": 500}
      },
      "message": "Payment API health check failed. @slack-oncall",
      "tags": ["service:payment-api", "env:prod"],
      "status": "live",
      "locations": ["aws:us-east-1", "aws:eu-west-1", "aws:ap-southeast-1"]
    },
    {
      "public_id": "syn-def-456",
      "name": "Homepage Browser Test",
      "type": "browser",
      "config": {
        "request": {
          "url": "https://www.example.com"
        },
        "steps": [
          {
            "name": "Navigate to homepage",
            "type": "navigate",
            "params": {"url": "https://www.example.com"}
          },
          {
            "name": "Click login button",
            "type": "click",
            "params": {"element": "#login-btn"}
          },
          {
            "name": "Assert login form visible",
            "type": "assertElementPresent",
            "params": {"element": "#login-form"}
          }
        ]
      },
      "options": {
        "tick_every": 300,
        "min_failure_duration": 0,
        "min_location_failed": 1
      },
      "message": "Homepage browser test failed.",
      "tags": ["service:web-frontend", "env:prod"],
      "status": "live",
      "locations": ["aws:us-east-1", "aws:eu-west-1"]
    }
  ]
}
